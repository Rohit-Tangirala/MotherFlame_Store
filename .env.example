# ==============================================================================
# STOREFRONT FULL-STACK ENVIRONMENT CONFIGURATION EXAMPLES
# ==============================================================================

# Database Connection Settings (Aiven MySQL hosted with SSL)
MYSQL_HOST="your-mysql-hostname.aivencloud.com"
MYSQL_PORT="12345"
MYSQL_USER="avnadmin"
MYSQL_PASSWORD="your_aiven_secure_password"
MYSQL_DATABASE="defaultdb"

# Or use a full Connection URI/URL if preferred
MYSQL_URI="mysql://avnadmin:password@hostname:port/defaultdb?ssl-mode=REQUIRED"

# JWT Authentication secret
JWT_SECRET="generate_a_secure_long_random_string_here"

# Resend Email SMTP key (On orders, confirmations are sent using this key)
RESEND_API_KEY="re_123456789_abcdefg"

# Cloudinary Storage settings (For admin product image uploads)
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="123456789012345"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

# Server / App URLs (Injected automatically at runtime by AI Studio)
APP_URL="https://ais-dev-your-app-id.run.app"
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
